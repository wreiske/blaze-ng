{
  "name": "@blaze-ng/observe-sequence",
  "version": "0.1.0",
  "description": "Reactive array/cursor observation for Blaze-NG",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --declaration --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "MIT"
}
