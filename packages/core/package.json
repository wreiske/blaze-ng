{
  "name": "@blaze-ng/core",
  "version": "0.1.0",
  "description": "Core view engine, rendering, DOM, and events for Blaze-NG",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "@blaze-ng/htmljs": "workspace:*",
    "@blaze-ng/observe-sequence": "workspace:*"
  }
}
